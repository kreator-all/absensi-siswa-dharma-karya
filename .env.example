# Database URL (SQLite untuk development, ganti ke PostgreSQL/MySQL untuk production)
DATABASE_URL="file:./db/custom.db"

# JWT Secret (GANTI dengan secret yang aman minimal 32 karakter!)
JWT_SECRET="ganti-dengan-secret-key-yang-aman-dan-panjang-minimal-32-karakter"

# Environment
NODE_ENV="production"

# Optional: Untuk production dengan PostgreSQL
# DATABASE_URL="postgresql://user:password@localhost:5432/absensi_db"
